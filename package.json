    "verify:package": "node scripts/verify-update.mjs && node scripts/verify-package.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "adm-zip": "^0.5.16",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
