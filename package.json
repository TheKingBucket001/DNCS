  "description": "通过 UID 级双栈防火墙规则控制 Android 应用联网的 Root 模块。",
  "license": "GPL-3.0-only",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "package": "node scripts/package.mjs",
    "typecheck": "tsc --noEmit",
